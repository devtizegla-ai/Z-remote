{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Z-Remote",
  "version": "0.1.0",
  "identifier": "com.zremote.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Z-Remote",
        "width": 1320,
        "height": 840,
        "resizable": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: data: blob:; connect-src 'self' http: https: ws: wss:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}

