APP_ENV=development
SERVER_ADDR=:8080
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=remote-access-mvp
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
SESSION_TOKEN_TTL=2h
DB_DRIVER=sqlite
DB_URL=./data/remote_access.db
CORS_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m
FILE_MAX_BYTES=10485760
FILE_STORAGE_DIR=./data/uploads
SEED_DEV_DATA=false

